// Test: Negative index for Array.get raises catchable exception
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let arr = Array.ofList [10; 20; 30]
let neg = 0 - 1
let r = try Array.get arr neg with e -> 0 - 999
let _ = println (to_string r)
// --- Output:
-999
