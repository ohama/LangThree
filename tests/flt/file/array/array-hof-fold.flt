// Test: Array.fold accumulates result across all elements (TST-20)
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let arr = Array.ofList [1; 2; 3; 4; 5]
let sum = Array.fold (fun acc -> fun x -> acc + x) 0 arr
let _ = println (to_string sum)
// --- Output:
15
