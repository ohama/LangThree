// Test: Array.map transforms each element, producing a new array (TST-20)
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let arr = Array.ofList [1; 2; 3]
let doubled = Array.map (fun x -> x * 2) arr
let _ = println (to_string (Array.get doubled 0))
let _ = println (to_string (Array.get doubled 1))
let _ = println (to_string (Array.get doubled 2))
// --- Output:
2
4
6
