// Test: Array.fold with string accumulator
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let arr = Array.ofList ["a"; "b"; "c"]
let result = Array.fold (fun acc -> fun x -> string_concat acc x) "" arr
let _ = println result
// --- Output:
abc
