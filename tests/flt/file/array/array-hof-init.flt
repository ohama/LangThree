// Test: Array.init creates array from index function (TST-20)
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let arr = Array.init 4 (fun i -> i * i)
let _ = println (to_string (Array.get arr 0))
let _ = println (to_string (Array.get arr 1))
let _ = println (to_string (Array.get arr 2))
let _ = println (to_string (Array.get arr 3))
// --- Output:
0
1
4
9
