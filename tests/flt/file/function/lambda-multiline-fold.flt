// Test: chained fun -> with multiline body
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let rec fold f = fun acc -> fun xs ->
    match xs with
    | [] -> acc
    | h :: t -> fold f (f acc h) t

let result = fold (fun a -> fun x -> a + x) 0 [1..10]
// --- Output:
55
