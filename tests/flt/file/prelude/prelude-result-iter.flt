// Test: Prelude resultIter applies function to Ok, skips Error
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let _ = resultIter (fun x -> println (to_string x)) (Ok 42)
let _ = resultIter (fun x -> println (to_string x)) (Error "oops")
// --- Output:
42
