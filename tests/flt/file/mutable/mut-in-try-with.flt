// Test: mutable variable used in try-with
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
exception E

let result =
    let mut x = 0
    let _ =
        try
            let _ = x <- 42
            raise E
        with
        | E -> x <- x + 1
    x
// --- Output:
43
