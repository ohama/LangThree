let sb = StringBuilder ()
let r1 = sb.Append "a"
let r2 = r1.Append "b"
let r3 = r2.Append "c"
let result = r3.ToString ()
let _ = println result
let _ = println (to_string (result = "abc"))
// --- Output:
abc
true
()
