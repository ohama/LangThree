// Test: String slicing s.[start..stop] and s.[start..] (LANG-01)
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let s = "hello"
let _ = println (s.[1..3])
let _ = println (s.[2..])
let _ = println (s.[0..0])
let _ = println (s.[4..])
let t = "abcdef"
let _ = println (t.[0..2])
let _ = println (t.[3..5])
// --- Output:
ell
llo
h
o
abc
def
()
