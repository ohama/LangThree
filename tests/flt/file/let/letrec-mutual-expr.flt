// Test: expression-level mutual recursion with let rec ... and ... in
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
// Classic even/odd mutual recursion
let _ = println (to_string (let rec even n = if n = 0 then true else odd (n - 1) and odd n = if n = 0 then false else even (n - 1) in even 10))
let _ = println (to_string (let rec even n = if n = 0 then true else odd (n - 1) and odd n = if n = 0 then false else even (n - 1) in odd 10))

// Three mutually recursive functions (mod 3 cycle)
let _ = println (to_string (let rec a n = if n = 0 then 0 else b (n - 1) and b n = if n = 0 then 1 else c (n - 1) and c n = if n = 0 then 2 else a (n - 1) in a 7))

// With param type annotations
let _ = println (to_string (let rec f (x : int) = if x = 0 then true else g (x - 1) and g (y : int) = if y = 0 then false else f (y - 1) in f 5))

// With return type annotations
let _ = println (to_string (let rec f (x : int) : bool = if x = 0 then true else g (x - 1) and g (y : int) : bool = if y = 0 then false else f (y - 1) in f 4))

// Nested inside a function body (single-line to avoid indent filter issues with `and`)
let test x = let rec even n = if n = 0 then true else odd (n - 1) and odd n = if n = 0 then false else even (n - 1) in even x
let _ = println (to_string (test 6))

// Nested inside a match arm
let check x =
    match x with
    | 0 -> false
    | n -> let rec even k = if k = 0 then true else odd (k - 1) and odd k = if k = 0 then false else even (k - 1) in even n
let _ = println (to_string (check 4))

// Single binding regression
let _ = println (to_string (let rec f x = if x = 0 then 1 else x * f (x - 1) in f 5))
// --- Output:
true
false
1
false
true
true
true
120
()
