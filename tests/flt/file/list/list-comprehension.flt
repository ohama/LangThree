// Test: List comprehension [for x in coll -> expr] and range variant (LANG-02)
// --- Command: /Users/ohama/vibe/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let doubled = [for x in [1;2;3] -> x * 2]
let _ = println (to_string doubled)
let squares = [for i in 0..4 -> i * i]
let _ = println (to_string squares)
let strs = [for s in ["a";"b";"c"] -> s ^^ "!"]
let _ = println (to_string strs)
// --- Output:
[2; 4; 6]
[0; 1; 4; 9; 16]
["a!"; "b!"; "c!"]
()
