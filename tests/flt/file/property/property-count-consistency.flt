// Test: .Count property consistency across all collection types (PROP-02)
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let hs = HashSet.create ()
let _ = HashSet.add hs 1
let _ = HashSet.add hs 2
let q = Queue.create ()
let _ = Queue.enqueue q 10
let _ = Queue.enqueue q 20
let _ = Queue.enqueue q 30
let ml = MutableList.create ()
let _ = MutableList.add ml "a"
let ht = Hashtable.create ()
let _ = Hashtable.set ht "x" 1
let _ = Hashtable.set ht "y" 2
let _ = println (to_string (HashSet.count hs))
let _ = println (to_string (Queue.count q))
let _ = println (to_string (MutableList.count ml))
let _ = println (to_string (Hashtable.count ht))
// --- Output:
2
3
1
2
()
