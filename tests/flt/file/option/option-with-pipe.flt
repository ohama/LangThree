// Test: Option with pipe operator
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let optionMap f opt = match opt with
| Some x -> Some (f x)
| None -> None

let double x = x * 2
let inc x = x + 1

let result = Some 5 |> optionMap double |> optionMap inc
// --- Output:
Some 11
