// Test: insertion sort algorithm
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let sorted =
    let rec insert x = fun xs ->
        match xs with
        | [] -> x :: []
        | h :: t -> if x <= h then x :: h :: t else h :: insert x t
    in
    let rec sort xs = match xs with | [] -> [] | h :: t -> insert h (sort t)
    in sort [5, 3, 8, 1, 9, 2, 7, 4, 6]

let result = sorted
// --- Output:
[1, 2, 3, 4, 5, 6, 7, 8, 9]
