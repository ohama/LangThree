// Test: greatest common divisor and least common multiple
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let result =
    let rec gcd a = fun b ->
        if b = 0 then a else gcd b (a - (a / b) * b)
    let lcm = fun a -> fun b -> a / gcd a b * b
    (gcd 48 36, lcm 12 18)
// --- Output:
(12, 36)
