// Test: Queue.Dequeue on empty queue raises exception (COLL-03)
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let q = Queue.create ()
let result =
    try
        let _ = Queue.dequeue q ()
        "no error"
    with
    | e -> "caught: " ^^ e
let _ = println result
// --- Output:
caught: Queue.Dequeue: queue is empty
()
