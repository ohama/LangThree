// Test: nested Option pattern matching using Prelude Option
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let flatten opt = match opt with
| Some (Some x) -> Some x
| _ -> None

let r1 = flatten (Some (Some 42))
let r2 = flatten (Some None)
let r3 = flatten None

let show opt = match opt with
| Some x -> to_string x
| None -> "none"

let result = show r1 + " " + show r2 + " " + show r3
// --- Output:
"42 none none"
