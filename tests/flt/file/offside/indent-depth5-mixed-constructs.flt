// Test: mixed constructs (let -> match -> if -> let -> try) at depth 5
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
exception NotFound

let process x =
    let category =
        match x with
        | 0 -> "zero"
        | n ->
            if n > 0 then
                let tag =
                    try
                        let v = 100 / n
                        to_string v
                    with
                    | _ -> "error"
                string_concat "pos:" tag
            else
                let abs_n = 0 - n
                let tag =
                    try
                        let v = 100 / abs_n
                        to_string v
                    with
                    | _ -> "error"
                string_concat "neg:" tag
    category

let _ = println (process 5)
let _ = println (process (0 - 4))
let _ = println (process 0)
// --- Output:
pos:20
neg:25
zero
