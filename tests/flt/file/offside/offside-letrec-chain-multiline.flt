// Test: multiple let rec with multiline fun -> bodies
// --- Command: src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let sorted =
    let rec filter pred = fun xs ->
        match xs with
        | [] -> []
        | h :: t -> if pred h then h :: filter pred t else filter pred t
    let rec qsort xs =
        match xs with
        | [] -> []
        | p :: rest -> qsort (filter (fun x -> x < p) rest) ++ [p] ++ qsort (filter (fun x -> x >= p) rest)
    qsort [5, 3, 8, 1, 9, 2, 7]

let result = sorted
// --- Output:
[1, 2, 3, 5, 7, 8, 9]
