// Test: let bindings inside match clause bodies at depth 5
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let classify x =
    match x with
    | 0 -> "zero"
    | n ->
        let sign =
            if n > 0 then
                let pos = "positive"
                pos
            else
                let neg = "negative"
                neg
        let label =
            let abs_n = if n > 0 then n else 0 - n
            let s = to_string abs_n
            string_concat sign (string_concat ":" s)
        label

let _ = println (classify 42)
let _ = println (classify (0 - 7))
let _ = println (classify 0)
// --- Output:
positive:42
negative:7
zero
