// Test: INFIXOP1 operators (starting with @) are right-associative
// @@ is INFIXOP1, right-associative: a @@ b @@ c = a @@ (b @@ c)
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let (@@) f x = f x
let double x = x * 2
let inc x = x + 1
let result = double @@ inc @@ 5
// --- Output:
12
