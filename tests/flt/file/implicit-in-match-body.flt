// Test: implicit in -- let inside match clause body
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let classify x =
    match x with
    | 0 -> "zero"
    | n ->
        let abs_n = if n > 0 then n else 0 - n
        to_string abs_n

let result = classify (0 - 5)
// --- Output:
"5"
