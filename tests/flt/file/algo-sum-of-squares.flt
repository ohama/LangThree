// Test: sum of squares using fold
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let result =
    let rec fold f = fun acc -> fun xs -> match xs with | [] -> acc | h :: t -> fold f (f acc h) t
    in fold (fun acc -> fun x -> acc + x * x) 0 [1, 2, 3, 4, 5]
// --- Output:
55
