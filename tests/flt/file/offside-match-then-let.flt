// Test: match result into let, then continue chain
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let result =
    let grade = match 85 with | s when s >= 90 -> "A" | s when s >= 80 -> "B" | _ -> "C"
    let msg = "Grade: " ^^ grade
    msg
// --- Output:
"Grade: B"
