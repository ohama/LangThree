// Test: list patterns for precise length matching
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let describe xs =
    match xs with
    | [] -> "empty"
    | x :: [] -> "singleton: " + to_string x
    | x :: y :: [] -> "pair: " + to_string x + "," + to_string y
    | x :: y :: z :: _ -> "three+: " + to_string x + "," + to_string y + "," + to_string z

let r1 = describe []
let r2 = describe [42]
let r3 = describe [1; 2]
let r4 = describe [10; 20; 30; 40]
let result = r1 + " | " + r2 + " | " + r3 + " | " + r4
// --- Output:
"empty | singleton: 42 | pair: 1,2 | three+: 10,20,30"
