// Test: list literal patterns in match - [x], [x; y], [x; y; z]
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let describe xs =
    match xs with
    | [] -> "empty"
    | [x] -> "one"
    | [x; y] -> "two"
    | [x; y; z] -> "three"
    | _ -> "many"

let r1 = describe []
let r2 = describe [1]
let r3 = describe [1; 2]
let r4 = describe [1; 2; 3]
let r5 = describe [1; 2; 3; 4]
let result = r1 + " " + r2 + " " + r3 + " " + r4 + " " + r5
// --- Output:
"empty one two three many"
