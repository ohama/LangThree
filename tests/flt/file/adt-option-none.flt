// Test: Option-style ADT with None case
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
type Opt 'a = None | Some of 'a

let getOrDefault opt def = match opt with
| Some x -> x
| None -> def

let result = getOrDefault None 99
// --- Output:
99
