// Test: ++ operator used inside match body
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let combine xs = match xs with | [] -> [0] | _ -> xs ++ [99]
let r1 = combine [1, 2]
let r2 = combine []
let result = (r1, r2)
// --- Output:
([1, 2, 99], [0])
