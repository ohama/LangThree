// Test: exception handler with when guard
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
exception MyError of int

let result = try
    raise (MyError 5)
with
| MyError x when x > 0 -> "positive"
| MyError _ -> "other"
// --- Output:
"positive"
