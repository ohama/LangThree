// Test: instance declaration parses to InstanceDecl AST node
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree --emit-ast %input
// --- Input:
instance Show int =
    let show x = to_string x
// --- Output:
InstanceDecl "Show" TEInt [show = Lambda ("x", App (Var "to_string", Var "x"))]
