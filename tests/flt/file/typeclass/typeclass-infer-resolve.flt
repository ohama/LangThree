// Test: show_twice resolves Show int and Show bool at distinct use sites
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree --check %input
// --- Input:
typeclass Show 'a =
    | show : 'a -> string

instance Show int =
    let show x = to_string x

instance Show bool =
    let show x = if x then "true" else "false"

let show_twice x = show x + show x

let _ = show_twice 42
let _ = show_twice true
// --- Stderr:
OK (0 warnings)
