// Test: typeclass and instance declarations together parse to separate AST nodes
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree --emit-ast %input
// --- Input:
typeclass Show 'a =
    | show : 'a -> string
instance Show int =
    let show x = to_string x
// --- Output:
TypeClassDecl "Show" 'a [show : TEArrow (TEVar "'a", TEString)]
InstanceDecl "Show" TEInt [show = Lambda ("x", App (Var "to_string", Var "x"))]
