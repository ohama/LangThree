// Test: MutableList index read and write (COLL-04, .[i] indexing)
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let ml = MutableList.create ()
let _ = MutableList.add ml 100
let _ = MutableList.add ml 200
let _ = println (to_string ml.[0])
let _ = ml.[0] <- 999
let _ = println (to_string ml.[0])
let _ = println (to_string ml.[1])
let _ = println (to_string (MutableList.count ml))
// --- Output:
100
999
200
2
()
