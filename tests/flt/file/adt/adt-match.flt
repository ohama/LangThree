// Test: pattern matching on ADT constructors
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
type Color =
    | Red
    | Green
    | Blue

let describe c = match c with
| Red -> "red"
| Green -> "green"
| Blue -> "blue"

let result = describe Green
// --- Output:
"green"
