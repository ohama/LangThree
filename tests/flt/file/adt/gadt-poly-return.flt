// Test: GADT match with type variable annotation
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
type Expr 'a =
    | IntLit : int -> int Expr
    | BoolLit : bool -> bool Expr

let f e =
    (match e with
    | IntLit n -> n
    | BoolLit b -> if b then 1 else 0
    : 'a)

let result = f (IntLit 42)
// --- Output:
42
