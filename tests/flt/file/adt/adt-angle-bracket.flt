type Result<'a> = Ok of 'a | Error of string
let extract item = match item with | Ok v -> v | Error _ -> 0
let items = [Ok 10; Ok 20; Error "bad"; Ok 5]
let values = List.map extract items
let result = List.fold (fun acc -> fun v -> acc + v) 0 values
