// Test: ADT with two type parameters (Either type)
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
type Either 'a 'b =
    | Left of 'a
    | Right of 'b

let getLeft e def = match e with
| Left x -> x
| Right _ -> def

let r1 = getLeft (Left 42) 0
let r2 = getLeft (Right "err") 99
let result = r1 + r2
// --- Output:
141
