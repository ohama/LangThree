let eq1 = if Some 1 = Some 1 then "eq" else "ne"
let eq2 = if Some 1 = Some 2 then "eq" else "ne"
let eq3 = if None = None then "eq" else "ne"
let eq4 = if Some 1 <> None then "ne" else "eq"
