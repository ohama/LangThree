// Test: for-in iteration over Hashtable with tuple destructuring (LANG-03, PROP-05)
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let ht = Hashtable.create ()
let _ = Hashtable.set ht "name" "Alice"
let _ = for (k, v) in ht do
  let _ = println k
  println v
// --- Output:
name
Alice
()
