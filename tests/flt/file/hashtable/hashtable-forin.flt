// Test: for-in iteration over Hashtable with kv.Key and kv.Value (LANG-03, PROP-05)
// --- Command: /Users/ohama/vibe/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let ht = Hashtable.create ()
let _ = Hashtable.set ht "name" "Alice"
let _ = for kv in ht do
  let _ = println kv.Key
  println kv.Value
// --- Output:
name
Alice
()
