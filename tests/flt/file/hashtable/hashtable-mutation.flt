// Test: Hashtable.set overwrites existing key (HT-03 mutation)
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let ht = Hashtable.create ()
let _ = Hashtable.set ht "k" 1
let _ = Hashtable.set ht "k" 99
let _ = println (to_string (Hashtable.get ht "k"))
// --- Output:
99
