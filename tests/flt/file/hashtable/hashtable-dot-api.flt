// Test: Hashtable dot API — TryGetValue, Count, Keys (COLL-05, PROP-02, PROP-03)
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let ht = Hashtable.create ()
let _ = Hashtable.set ht "x" 42
let _ = Hashtable.set ht "y" 99
let r1 = ht.TryGetValue("x")
let r2 = ht.TryGetValue("missing")
let _ = println (to_string r1)
let _ = println (to_string r2)
let _ = println (to_string ht.Count)
let ks = ht.Keys
let _ = println (to_string (List.length ks))
// --- Output:
(true, 42)
(false, ())
2
2
()
