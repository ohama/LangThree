// Test: Hashtable set-get-overwrite-get sequence
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let ht = Hashtable.create ()
let _ = Hashtable.set ht "k" 1
let _ = println (to_string (Hashtable.get ht "k"))
let _ = Hashtable.set ht "k" 2
let _ = println (to_string (Hashtable.get ht "k"))
let _ = Hashtable.set ht "k" 3
let _ = println (to_string (Hashtable.get ht "k"))
let _ = Hashtable.remove ht "k"
let _ = println (to_string (Hashtable.containsKey ht "k"))
// --- Output:
1
2
3
false
