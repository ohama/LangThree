// Test: Hashtable.remove removes entry so containsKey returns false (HT-06)
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let ht = Hashtable.create ()
let _ = Hashtable.set ht "key" 42
let _ = Hashtable.remove ht "key"
let _ = println (to_string (Hashtable.containsKey ht "key"))
// --- Output:
false
