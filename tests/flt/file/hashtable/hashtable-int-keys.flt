// Test: Hashtable with integer keys
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let ht = Hashtable.create ()
let _ = Hashtable.set ht 1 "one"
let _ = Hashtable.set ht 2 "two"
let _ = Hashtable.set ht 3 "three"
let _ = println (Hashtable.get ht 1)
let _ = println (Hashtable.get ht 3)
let _ = println (to_string (Hashtable.containsKey ht 2))
let _ = println (to_string (Hashtable.containsKey ht 99))
// --- Output:
one
three
true
false
