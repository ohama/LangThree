// Test: tail call in match expression with 1M iterations
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let result =
    let rec countdown n = match n with | 0 -> "done" | n -> countdown (n - 1)
    countdown 1000000
// --- Output:
"done"
