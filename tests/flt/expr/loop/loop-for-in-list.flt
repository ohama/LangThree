// Test FORIN-01: for-in iterates list elements in order
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let mut total = 0
let _ =
    for x in [1; 2; 3; 4] do
        total <- total + x
let _ = println (to_string total)
// --- Output:
10
()
