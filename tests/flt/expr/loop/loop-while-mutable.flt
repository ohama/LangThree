// Test LOOP-01: while loop with indented body using semicolon sequencing
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree %input
// --- Input:
let mut count = 0
let mut sum = 0
let _ =
    while count < 4 do
        sum <- sum + count; count <- count + 1
let _ = println (to_string sum)
// --- Output:
6
()
