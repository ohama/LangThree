// Test: --emit-type for function using match on ADT
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree --emit-type %input
// --- Input:
type Color = Red | Green | Blue

let name c =
    match c with
    | Red -> "red"
    | Green -> "green"
    | Blue -> "blue"
// --- Output:
name : Color -> string
