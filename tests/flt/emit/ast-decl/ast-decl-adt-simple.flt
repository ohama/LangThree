// Test: --emit-ast for simple ADT type declaration with constructor usage
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree --emit-ast %input
// --- Input:
type Color = Red | Green | Blue
let c = Red
// --- Output:
TypeDecl "Color" [| Red | Green | Blue]
LetDecl ("c", Constructor "Red")
