// Test: --emit-ast for mutually recursive type declarations
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree --emit-ast %input
// --- Input:
type A = X | Y of B
and B = P | Q of A
// --- Output:
TypeDecl "A" [| X | Y of TEName "B"]
TypeDecl "B" [| P | Q of TEName "A"]
