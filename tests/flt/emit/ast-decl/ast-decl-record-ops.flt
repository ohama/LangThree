// --- Input:
type Point = { x: int; y: int }
let p = { x = 1; y = 2 }
let a = p.x
let q = { p with x = 10 }
// --- Output:
RecordDecl "Point" {x: TEInt; y: TEInt}
LetDecl ("p", RecordExpr ({x = Number 1; y = Number 2}))
LetDecl ("a", FieldAccess (Var "p", x))
LetDecl ("q", RecordUpdate (Var "p", {x = Number 10}))
