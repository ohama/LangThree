// Test: --emit-ast for match expression with constructor patterns (file mode)
// --- Command: /Users/ohama/vibe-coding/LangThree/src/LangThree/bin/Release/net10.0/LangThree --emit-ast %input
// --- Input:
type Color =
    | Red
    | Green
    | Blue
let name c =
  match c with
  | Red -> 1
  | Green -> 2
  | Blue -> 3
// --- Output:
TypeDecl "Color" [| Red | Green | Blue]
LetDecl ("name", Lambda ("c", Match (Var "c", [(ConstructorPat "Red", Number 1); (ConstructorPat "Green", Number 2); (ConstructorPat "Blue", Number 3)])))
